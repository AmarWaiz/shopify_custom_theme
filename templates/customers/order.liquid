<div class="account page-width">
  <h1 style="text-align:left;">{{ 'customers.orders.order_number' | t }} {{ order.name }}</h1>
  <p class="text-muted">{{ order.created_at | date: '%B %d, %Y %I:%M %p' }}</p>

  <table class="account-table" style="margin-top:1.5rem;">
    <thead><tr><th>Product</th><th>SKU</th><th>Price</th><th>Qty</th><th>Total</th></tr></thead>
    <tbody>
      {%- for line in order.line_items -%}
        <tr>
          <td><a href="{{ line.product.url }}" class="link">{{ line.title }}</a></td>
          <td>{{ line.sku }}</td>
          <td>{{ line.price | money }}</td>
          <td>{{ line.quantity }}</td>
          <td>{{ line.final_line_price | money }}</td>
        </tr>
      {%- endfor -%}
    </tbody>
    <tfoot>
      <tr><td colspan="4">{{ 'cart.subtotal' | t }}</td><td>{{ order.line_items_subtotal_price | money }}</td></tr>
      {%- for discount in order.cart_level_discount_applications -%}<tr><td colspan="4">{{ discount.title }}</td><td>−{{ discount.total_allocated_amount | money }}</td></tr>{%- endfor -%}
      {%- for shipping in order.shipping_methods -%}<tr><td colspan="4">{{ shipping.title }}</td><td>{{ shipping.price | money }}</td></tr>{%- endfor -%}
      {%- for tax in order.tax_lines -%}<tr><td colspan="4">{{ tax.title }} ({{ tax.rate | times: 100 }}%)</td><td>{{ tax.price | money }}</td></tr>{%- endfor -%}
      <tr><td colspan="4"><strong>{{ 'customers.orders.total' | t }}</strong></td><td><strong>{{ order.total_net_amount | money }}</strong></td></tr>
    </tfoot>
  </table>

  <div class="address-grid" style="margin-top:2rem;">
    <div class="address-card"><h3 class="h6">Billing</h3><address class="rte">{{ order.billing_address | format_address }}</address></div>
    <div class="address-card"><h3 class="h6">Shipping</h3><address class="rte">{{ order.shipping_address | format_address }}</address></div>
  </div>
  <p style="margin-top:1.5rem;"><a href="{{ routes.account_url }}" class="link">← {{ 'customers.account.title' | t }}</a></p>
</div>
