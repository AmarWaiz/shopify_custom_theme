<div class="account account__narrow page-width">
  <h1>{{ 'customers.login.title' | t }}</h1>

  {%- form 'customer_login', novalidate: 'novalidate' -%}
    {%- if form.errors -%}<div class="account__errors">{{ form.errors | default_errors }}</div>{%- endif -%}
    <div class="field">
      <label class="field__label" for="customer-email">{{ 'customers.login.email' | t }}</label>
      <input type="email" id="customer-email" name="customer[email]" autocomplete="email" required>
    </div>
    <div class="field">
      <label class="field__label" for="customer-password">{{ 'customers.login.password' | t }}</label>
      <input type="password" id="customer-password" name="customer[password]" autocomplete="current-password" required>
    </div>
    <a href="#recover" class="link" onclick="document.getElementById('recover').style.display='block';return false;">{{ 'customers.login.forgot_password' | t }}</a>
    <button type="submit" class="btn btn--full" style="margin-top:1rem;">{{ 'customers.login.submit' | t }}</button>
  {%- endform -%}

  <p class="account__alt">{{ 'customers.login.create_account' | t }}: <a href="{{ routes.account_register_url }}" class="link">{{ 'customers.register.title' | t }}</a></p>

  <div id="recover" style="display:none; margin-top:2rem; border-top:1px solid var(--color-border); padding-top:2rem;">
    <h2 class="h4">{{ 'customers.recover_password.title' | t }}</h2>
    <p class="text-muted">{{ 'customers.recover_password.subtext' | t }}</p>
    {%- form 'recover_customer_password' -%}
      {%- if form.posted_successfully? -%}<p style="color:var(--color-success)">{{ 'customers.recover_password.success' | t }}</p>{%- endif -%}
      <div class="field"><label class="field__label" for="recover-email">{{ 'customers.recover_password.email' | t }}</label><input type="email" id="recover-email" name="email" required></div>
      <button type="submit" class="btn">{{ 'customers.recover_password.submit' | t }}</button>
    {%- endform -%}
  </div>
</div>
