<div class="account account__narrow page-width">
  <h1>{{ 'customers.register.title' | t }}</h1>
  {%- form 'create_customer', novalidate: 'novalidate' -%}
    {%- if form.errors -%}<div class="account__errors">{{ form.errors | default_errors }}</div>{%- endif -%}
    <div class="field"><label class="field__label" for="r-first">{{ 'customers.register.first_name' | t }}</label><input type="text" id="r-first" name="customer[first_name]" autocomplete="given-name"></div>
    <div class="field"><label class="field__label" for="r-last">{{ 'customers.register.last_name' | t }}</label><input type="text" id="r-last" name="customer[last_name]" autocomplete="family-name"></div>
    <div class="field"><label class="field__label" for="r-email">{{ 'customers.register.email' | t }}</label><input type="email" id="r-email" name="customer[email]" autocomplete="email" required></div>
    <div class="field"><label class="field__label" for="r-pass">{{ 'customers.register.password' | t }}</label><input type="password" id="r-pass" name="customer[password]" autocomplete="new-password" required></div>
    <button type="submit" class="btn btn--full">{{ 'customers.register.submit' | t }}</button>
  {%- endform -%}
  <p class="account__alt"><a href="{{ routes.account_login_url }}" class="link">{{ 'customers.login.title' | t }}</a></p>
</div>
