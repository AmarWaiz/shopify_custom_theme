<section class="password-page">
  <div class="password-page__inner">
    {%- if section.settings.logo != blank -%}
      <img src="{{ section.settings.logo | image_url: width: 360 }}" alt="{{ shop.name | escape }}" width="180" height="auto" style="max-height:48px;width:auto;margin-inline:auto;">
    {%- else -%}
      <h1 class="password-page__logo">{{ shop.name }}</h1>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}<h2 class="password-page__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.text != blank -%}<div class="rte password-page__text">{{ section.settings.text }}</div>{%- endif -%}

    {%- form 'storefront_password', class: 'password-page__form' -%}
      {%- if form.errors -%}<p class="password-page__error">{{ form.errors.translated_fields.password | capitalize }} {{ form.errors.messages.password }}</p>{%- endif -%}
      <div class="password-page__row">
        <input type="password" name="password" placeholder="{{ 'password.password' | t }}" aria-label="{{ 'password.password' | t }}" required>
        <button type="submit" class="btn">{{ 'password.enter' | t }}</button>
      </div>
    {%- endform -%}

    <p class="password-page__powered">{{ 'password.powered_by' | t }}</p>
  </div>
</section>

{% stylesheet %}
  .password-page { min-height: 100dvh; display: grid; place-items: center; padding: 2rem; background: var(--color-bg-soft); text-align: center; }
  .password-page__inner { max-width: 420px; display: flex; flex-direction: column; gap: 1rem; }
  .password-page__logo { font-family: var(--font-heading); font-size: 2rem; }
  .password-page__heading { font-size: var(--font-h3); }
  .password-page__row { display: flex; gap: 0.5rem; }
  .password-page__row input { flex: 1; padding: 0.9rem 1rem; border: 1px solid var(--color-border); border-radius: var(--radius); }
  .password-page__error { color: var(--color-sale); font-size: var(--font-sm); }
  .password-page__powered { font-size: var(--font-xs); color: var(--color-text-soft); margin-top: 1rem; }
{% endstylesheet %}

{% schema %}
{
  "name": "Password",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "text", "id": "heading", "default": "Opening soon", "label": "Heading" },
    { "type": "richtext", "id": "text", "default": "<p>Be the first to know when we launch.</p>", "label": "Text" }
  ]
}
{% endschema %}
