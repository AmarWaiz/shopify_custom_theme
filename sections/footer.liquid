<footer class="footer" style="background: {{ section.settings.bg }}; color: {{ section.settings.text }};">
  <div class="footer__inner page-width">
    <div class="footer__top">
      {%- for block in section.blocks -%}
        <div class="footer__col footer__col--{{ block.type }}" {{ block.shopify_attributes }}>
          {%- case block.type -%}
            {%- when 'brand' -%}
              {%- if block.settings.logo != blank -%}
                <img src="{{ block.settings.logo | image_url: width: 320 }}" alt="{{ shop.name | escape }}" width="160" height="auto" style="max-height: 44px; width: auto;">
              {%- else -%}
                <p class="footer__logo">{{ block.settings.heading | default: shop.name }}</p>
              {%- endif -%}
              {%- if block.settings.text != blank -%}<div class="footer__about rte">{{ block.settings.text }}</div>{%- endif -%}

            {%- when 'menu' -%}
              <h3 class="footer__heading">{{ block.settings.heading }}</h3>
              <ul class="footer__links">
                {%- for link in block.settings.menu.links -%}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{%- endfor -%}
              </ul>

            {%- when 'text' -%}
              <h3 class="footer__heading">{{ block.settings.heading }}</h3>
              <div class="rte">{{ block.settings.text }}</div>

            {%- when 'newsletter' -%}
              <h3 class="footer__heading">{{ block.settings.heading }}</h3>
              {%- if block.settings.subtext != blank -%}<p>{{ block.settings.subtext }}</p>{%- endif -%}
              {%- form 'customer', class: 'footer__newsletter' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                {%- if form.posted_successfully? -%}
                  <p class="footer__success">{{ 'general.newsletter.success' | t }}</p>
                {%- else -%}
                  <div class="footer__newsletter-row">
                    <input type="email" name="contact[email]" placeholder="{{ 'general.newsletter.placeholder' | t }}" required aria-label="{{ 'general.newsletter.label' | t }}">
                    <button type="submit" class="btn btn--sm">{{ 'general.newsletter.button' | t }}</button>
                  </div>
                {%- endif -%}
              {%- endform -%}
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      <div class="footer__social">
        {%- assign socials = 'instagram,facebook,tiktok,youtube,x,pinterest' | split: ',' -%}
        {%- for s in socials -%}
          {%- assign key = 'social_' | append: s -%}
          {%- assign url = settings[key] -%}
          {%- if url != blank -%}<a href="{{ url }}" class="footer__social-icon" aria-label="{{ s }}" target="_blank" rel="noopener">{% render 'icon', name: s, size: 18 %}</a>{%- endif -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.show_payment_icons -%}
        <div class="footer__payments">
          {%- for type in shop.enabled_payment_types -%}{{ type | payment_type_svg_tag: class: 'footer__payment' }}{%- endfor -%}
        </div>
      {%- endif -%}

      <p class="footer__copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright }}</p>
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer { border-top: 3px solid var(--color-accent); padding-block: var(--section-spacing); margin-top: var(--section-spacing); }
  .footer__top { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 2.5rem; padding-bottom: 2.5rem; border-bottom: 1px solid rgba(255,255,255,0.12); }
  .footer__col--brand { grid-column: span 1; max-width: 320px; }
  .footer__logo { font-family: var(--font-heading); font-size: 1.6rem; margin-bottom: 0.75rem; }
  .footer__about { font-size: var(--font-sm); opacity: 0.7; }
  .footer__heading { font-size: var(--font-xs); text-transform: uppercase; letter-spacing: var(--tracking-widest); color: var(--color-accent); margin-bottom: 1rem; }
  .footer__links { display: flex; flex-direction: column; gap: 0.6rem; }
  .footer__links a { font-size: var(--font-sm); opacity: 0.85; position: relative; transition: padding-left var(--t-base) var(--ease-out), opacity var(--t-base); }
  .footer__links a::before { content: ""; position: absolute; left: 0; top: 50%; width: 0; height: 1px; background: var(--color-accent); transform: translateY(-50%); transition: width var(--t-base) var(--ease-out); }
  .footer__links a:hover { opacity: 1; padding-left: 20px; }
  .footer__links a:hover::before { width: 14px; }
  .footer__newsletter-row { display: flex; gap: 0.5rem; margin-top: 0.75rem; }
  .footer__newsletter input { flex: 1; padding: 0.7rem 0.9rem; border: 1px solid rgba(255,255,255,0.25); background: transparent; color: inherit; border-radius: var(--radius); }
  .footer__newsletter input::placeholder { color: currentColor; opacity: 0.5; }
  .footer__success { margin-top: 0.75rem; color: var(--color-accent); }
  .footer__bottom { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem; padding-top: 1.75rem; }
  .footer__social { display: flex; gap: 0.75rem; }
  .footer__social-icon { opacity: 0.8; transition: opacity var(--t-fast), transform var(--t-fast) var(--ease-out); }
  .footer__social-icon:hover { opacity: 1; color: var(--color-accent); transform: translateY(-3px); }
  .footer__payments { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .footer__payment { width: 38px; height: auto; }
  .footer__copy { font-size: var(--font-xs); opacity: 0.6; }
  @media (max-width: 749px) { .footer__bottom { flex-direction: column; align-items: flex-start; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "color", "id": "bg", "default": "#191919", "label": "Background" },
    { "type": "color", "id": "text", "default": "#FFFFFF", "label": "Text" },
    { "type": "checkbox", "id": "show_payment_icons", "default": true, "label": "Show payment icons" },
    { "type": "text", "id": "copyright", "default": "All rights reserved.", "label": "Copyright text" }
  ],
  "blocks": [
    {
      "type": "brand", "name": "Brand", "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo" },
        { "type": "text", "id": "heading", "label": "Brand name" },
        { "type": "richtext", "id": "text", "default": "<p>Premium quality for modern living.</p>", "label": "Text" }
      ]
    },
    {
      "type": "menu", "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "default": "Shop", "label": "Heading" },
        { "type": "link_list", "id": "menu", "default": "footer", "label": "Menu" }
      ]
    },
    {
      "type": "text", "name": "Text column",
      "settings": [
        { "type": "text", "id": "heading", "default": "Contact", "label": "Heading" },
        { "type": "richtext", "id": "text", "default": "<p>hello@example.com<br>+1 (555) 000-0000</p>", "label": "Text" }
      ]
    },
    {
      "type": "newsletter", "name": "Newsletter", "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "default": "Newsletter", "label": "Heading" },
        { "type": "text", "id": "subtext", "default": "Get 10% off your first order.", "label": "Subtext" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "brand" }, { "type": "menu" }, { "type": "text" }, { "type": "newsletter" }
      ]
    }
  ]
}
{% endschema %}
