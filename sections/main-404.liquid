<section class="section main-404">
  <div class="page-width page-width--narrow text-center">
    <p class="eyebrow">404</p>
    <h1>{{ '404.title' | t }}</h1>
    <p class="main-404__text text-muted">{{ '404.not_found' | t }}</p>
    <a href="{{ routes.root_url }}" class="btn">{{ '404.back_to_shopping' | t }}</a>
  </div>
</section>

{% stylesheet %}
  .main-404 { padding-block: clamp(4rem, 10vw, 9rem); }
  .main-404 h1 { margin: 0.5rem 0 1rem; }
  .main-404__text { margin-bottom: 2rem; }
{% endstylesheet %}

{% schema %}
{ "name": "404", "settings": [] }
{% endschema %}
