<div class="section video-section color-{{ section.settings.color_scheme }}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}<div class="section-header" data-reveal><h2>{{ section.settings.heading }}</h2></div>{%- endif -%}
    <div class="video-wrap media" data-video data-reveal>
      {%- if section.settings.video != blank -%}
        {{ section.settings.video | video_tag: image_size: '1600x', controls: true, playsinline: true, class: 'video-el' }}
      {%- elsif section.settings.video_url != blank -%}
        <button type="button" class="video-poster" data-video-play aria-label="Play video">
          {%- if section.settings.cover != blank -%}
            <img src="{{ section.settings.cover | image_url: width: 1600 }}" alt="{{ section.settings.heading | escape }}" width="1600" height="900" loading="lazy">
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          <span class="video-poster__btn">{% render 'icon', name: 'chevron-right', size: 28 %}</span>
        </button>
        {%- liquid
          assign vid = section.settings.video_url
          if vid.type == 'youtube'
            assign embed = 'https://www.youtube.com/embed/' | append: vid.id | append: '?autoplay=1&rel=0'
          elsif vid.type == 'vimeo'
            assign embed = 'https://player.vimeo.com/video/' | append: vid.id | append: '?autoplay=1'
          endif
        -%}
        <template data-video-embed>
          <iframe src="{{ embed }}" title="{{ section.settings.heading | escape }}" allow="autoplay; encrypted-media; fullscreen" allowfullscreen loading="lazy"></iframe>
        </template>
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .video-wrap { aspect-ratio: 16 / 9; border-radius: var(--radius); }
  .video-wrap .video-el, .video-wrap iframe { width: 100%; height: 100%; object-fit: cover; border: 0; }
  .video-poster { position: relative; width: 100%; height: 100%; padding: 0; cursor: pointer; }
  .video-poster img { width: 100%; height: 100%; object-fit: cover; }
  .video-poster__btn { position: absolute; inset: 0; margin: auto; width: 72px; height: 72px; background: rgba(255,255,255,0.9); color: #111; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: transform var(--t-base) var(--ease-out); }
  .video-poster:hover .video-poster__btn { transform: scale(1.08); }
{% endstylesheet %}

<script>
  (function () {
    var s = document.currentScript.previousElementSibling;
    var btn = document.querySelector('[data-video-play]');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var tpl = btn.parentElement.querySelector('[data-video-embed]');
      if (tpl) { var frame = tpl.content.cloneNode(true); btn.replaceWith(frame); }
    });
  })();
</script>

{% schema %}
{
  "name": "Video",
  "settings": [
    { "type": "text", "id": "heading", "default": "Watch the film", "label": "Heading" },
    { "type": "video", "id": "video", "label": "Shopify-hosted video" },
    { "type": "video_url", "id": "video_url", "accept": ["youtube", "vimeo"], "label": "External video URL" },
    { "type": "image_picker", "id": "cover", "label": "Cover image (for external video)" },
    { "type": "header", "content": "Appearance" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "options": [
      { "value": "default", "label": "Default" }, { "value": "soft", "label": "Soft" }, { "value": "dark", "label": "Dark" }
    ], "default": "default" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64, "label": "Padding top" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64, "label": "Padding bottom" }
  ],
  "presets": [{ "name": "Video" }]
}
{% endschema %}
